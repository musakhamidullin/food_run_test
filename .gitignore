## Flutter/Dart .gitignore
# Miscellaneous
.DS_Store
.idea/
.vscode/
*.log

# Build output
build/
.flutter-plugins
.flutter-plugins-dependencies
.flutter-plugins

# Dependency directories
.dart_tool/
.packages
.pub/
.pub-cache/

# Generated files (by build_runner, json_serializable, retrofit)
*.g.dart
*.freezed.dart
*.mocks.dart

# iOS
ios/Flutter/Generated.xcconfig
ios/Pods/
ios/Podfile.lock
ios/Runner.xcworkspace/
ios/.symlinks/
ios/Flutter/Flutter.framework

# Android
android/.gradle/
android/app/debug/**
android/app/release/**
android/app/**/*.iml
android/app/build/
android/build/**
android/gradle/wrapper/**
android/gradle.properties
android/local.properties
android/.idea/

# Web
web/.dart_tool/
web/.packages

# Test coverage
coverage/

# Pubspec lock (optional if you want lock file versioned)
pubspec.lock

# Generated files for intl
intl/**/generated/**

# Other generated assets
generated/**
